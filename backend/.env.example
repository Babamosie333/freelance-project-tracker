PORT=4000

# MongoDB connection
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_DATABASE=freelance-tracker
MONGODB_ADMIN_USERNAME=your_admin_username
MONGODB_ADMIN_PASSWORD=your_admin_password
MONGODB_AUTH_SOURCE=admin

# Optional: set this to skip auto-building the URI from the fields above
# MONGODB_URI=mongodb://your_admin_username:your_admin_password@127.0.0.1:27017/freelance-tracker?authSource=admin

JWT_SECRET=change_this_to_a_long_random_string
